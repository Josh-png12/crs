# PostgreSQL pooled connection (used at runtime)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# PostgreSQL direct connection (used by Prisma migrations)
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# NextAuth v5 — generate with: openssl rand -base64 32
AUTH_SECRET=

# Public URL of the app (required for NextAuth callbacks)
NEXTAUTH_URL=https://your-app.vercel.app
