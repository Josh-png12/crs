// schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─── PERSONAS ───────────────────────────────────────────────

model Person {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  firstName       String
  lastName        String
  phone           String?
  whatsapp        String?
  email           String?
  birthDate       DateTime?
  gender          Gender?

  address         String?
  neighborhood    String?
  city            String?

  photoUrl        String?
  howTheyArrived  String?

  type            PersonType  @default(VISITOR)
  status          Status      @default(ACTIVE)
  joinedAt        DateTime?

  invitedById     String?
  invitedBy       Person?     @relation("Invitations", fields: [invitedById], references: [id])
  invitations     Person[]    @relation("Invitations")

  pastoralNotes   PastoralNote[]
  groupMembers    GroupMember[]
  attendances     Attendance[]
  pastoralVisits  PastoralVisit[]

  @@map("persons")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PersonType {
  MEMBER
  VISITOR
}

enum Status {
  ACTIVE
  INACTIVE
}

// ─── SERVICIOS / EVENTOS ────────────────────────────────────

model Service {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())

  name        String
  type        ServiceType
  date        DateTime
  notes       String?

  qrToken     String      @unique @default(cuid())
  isOpen      Boolean     @default(false)

  attendances Attendance[]

  @@map("services")
}

enum ServiceType {
  SUNDAY
  CELL
  SPECIAL
  YOUTH
  PRAYER
}

// ─── ASISTENCIA ─────────────────────────────────────────────

model Attendance {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())

  personId    String
  person      Person          @relation(fields: [personId], references: [id])

  serviceId   String
  service     Service         @relation(fields: [serviceId], references: [id])

  method      CheckInMethod   @default(DOORMAN)
  wasVisitor  Boolean         @default(false)

  @@unique([personId, serviceId])
  @@map("attendances")
}

enum CheckInMethod {
  QR
  DOORMAN
  MANUAL
}

// ─── GRUPOS / CÉLULAS ───────────────────────────────────────

model Group {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())

  name        String
  description String?
  leaderId    String?

  members     GroupMember[]

  @@map("groups")
}

model GroupMember {
  id        String    @id @default(cuid())
  joinedAt  DateTime  @default(now())

  personId  String
  person    Person    @relation(fields: [personId], references: [id])

  groupId   String
  group     Group     @relation(fields: [groupId], references: [id])

  role      GroupRole @default(MEMBER)

  @@unique([personId, groupId])
  @@map("group_members")
}

enum GroupRole {
  LEADER
  MEMBER
}

// ─── NOTAS PASTORALES ───────────────────────────────────────

model PastoralNote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  personId  String
  person    Person   @relation(fields: [personId], references: [id])

  content   String
  isPrivate Boolean  @default(true)

  @@map("pastoral_notes")
}

// ─── VISITAS PASTORALES ─────────────────────────────────────

model PastoralVisit {
  id          String   @id @default(cuid())
  visitedAt   DateTime
  createdAt   DateTime @default(now())

  personId    String
  person      Person   @relation(fields: [personId], references: [id])

  notes       String?
  outcome     String?

  @@map("pastoral_visits")
}

// ─── USUARIOS ADMIN ─────────────────────────────────────────

model User {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())

  name      String
  email     String    @unique
  password  String
  role      UserRole  @default(DOORMAN)

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  PASTOR
  DOORMAN
}
